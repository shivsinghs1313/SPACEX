# ============================================
# SPACEX Trading Academy — Environment Config
# Copy this to .env and fill in your values
# ============================================

# ---- App ----
APP_ENV=development
APP_URL=http://localhost
APP_DEBUG=true

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=spacex_trading
DB_USER=root
DB_PASS=

# ---- JWT ----
JWT_SECRET=spacex_trading_jwt_secret_key_change_in_production_2026
JWT_EXPIRY=604800

# ---- Razorpay ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_ENV=test

# ---- Video Storage ----
VIDEO_STORAGE_PATH=./videos
VIDEO_TOKEN_EXPIRY=7200
VIDEO_SIGNED_SECRET=spacex_video_signing_secret_change_me

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1
